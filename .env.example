# ── Supabase ──
# Your Supabase project URL (e.g., https://xxxx.supabase.co)
SUPABASE_URL=

# Supabase service role key — NEVER expose this client-side
SUPABASE_SERVICE_ROLE_KEY=

# ── Resend (email notifications) ──
# API key from https://resend.com/api-keys
RESEND_API_KEY=

# Email address to receive contact form notifications
NOTIFY_TO_EMAIL=
